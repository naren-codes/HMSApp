@model HMSApp.Models.Scan

@{
    ViewData["Title"] = "Send Scan to Doctor";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-send me-2"></i>Send Scan to Doctor
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                        </div>
                    }

                    <!-- Scan Information -->
                    <div class="mb-4">
                        <h6 class="text-muted mb-3">Scan Information</h6>
                        <div class="border rounded p-3 bg-light">
                            <div class="row">
                                <div class="col-sm-4"><strong>Scan Type:</strong></div>
                                <div class="col-sm-8">@Model.ScanType</div>
                            </div>
                            <div class="row">
                                <div class="col-sm-4"><strong>Lab Name:</strong></div>
                                <div class="col-sm-8">@Model.LabName</div>
                            </div>
                            <div class="row">
                                <div class="col-sm-4"><strong>Date:</strong></div>
                                <div class="col-sm-8">@Model.AppointmentDate.ToString("dd MMMM, yyyy")</div>
                            </div>
                            <div class="row">
                                <div class="col-sm-4"><strong>File:</strong></div>
                                <div class="col-sm-8">
                                    <a asp-action="ViewScanDocument" asp-controller="Patient" asp-route-id="@Model.Id" class="btn btn-info btn-sm" target="_blank">
                                        <i class="bi bi-eye me-1"></i>View Scan
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Send to Doctor Form -->
                    <form asp-action="SendScanToDoctor" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-3">
                            <label for="doctorId" class="form-label">
                                <i class="bi bi-person-badge me-1"></i>Select Doctor
                            </label>
                            <select name="doctorId" id="doctorId" class="form-select" required>
                                <option value="">-- Select a Doctor --</option>
                                @foreach (var doctor in ViewBag.Doctors as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)
                                {
                                    <option value="@doctor.Value">@doctor.Text</option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label for="message" class="form-label">
                                <i class="bi bi-chat-text me-1"></i>Message (Optional)
                            </label>
                            <textarea name="message" id="message" class="form-control" rows="3" 
                                      placeholder="Enter any additional information or questions for the doctor..."></textarea>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="AppointmentHistory" class="btn btn-secondary me-2">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send me-1"></i>Send to Doctor
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Add confirmation before sending
            $('form').on('submit', function(e) {
                var doctorText = $('#doctorId option:selected').text();
                if (doctorText && doctorText !== '-- Select a Doctor --') {
                    if (!confirm('Are you sure you want to send this scan to ' + doctorText + '?')) {
                        e.preventDefault();
                        return false;
                    }
                }
            });
        });
    </script>
}