@model HMSApp.Models.Scan
@{
    ViewData["Title"] = "Upload Scan";
}
<div class="container my-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-0">Upload Scan Document</h2>
        </div>
        <div class="card-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }

            <dl class="row">
                <dt class="col-sm-3">Patient</dt>
                <dd class="col-sm-9">@Model.PatientName</dd>
                <dt class="col-sm-3">Scan Type</dt>
                <dd class="col-sm-9">@Model.ScanType</dd>
                <dt class="col-sm-3">Appointment Date</dt>
                <dd class="col-sm-9">@Model.AppointmentDate.ToString("dd MMM yyyy")</dd>
                <dt class="col-sm-3">Current File</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.FileName))
                    {
                        <a href="~/uploads/@Model.FileName" target="_blank" class="btn btn-info btn-sm">View</a>
                    }
                    else
                    {
                        <span>No File</span>
                    }
                </dd>
            </dl>

            <form asp-action="Upload" asp-controller="Admin" method="post" enctype="multipart/form-data">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="mb-3">
                    <label for="scanFile" class="form-label">Select file (PDF/JPG/PNG)</label>
                    <input type="file" name="scanFile" id="scanFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png" required />
                </div>
                <button type="submit" class="btn btn-success">@(!string.IsNullOrEmpty(Model.FileName) ? "Re-upload" : "Upload")</button>
                <a asp-action="BookedScans" asp-controller="Admin" class="btn btn-secondary ms-2">Back</a>
            </form>
        </div>
    </div>
</div>